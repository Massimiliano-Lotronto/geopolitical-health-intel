# ============================
# CONFIGURAZIONE AMBIENTE
# Copia questo file come .env e compila i valori
# ============================

# --- Database (Supabase PostgreSQL - free tier 500MB) ---
# Registrati su https://supabase.com → New Project → Settings → Database
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# --- NCBI / PubMed API ---
# Registrati su https://www.ncbi.nlm.nih.gov/account/ → API Key
# Senza key: 3 req/sec. Con key: 10 req/sec
NCBI_API_KEY=your_ncbi_api_key_here
NCBI_EMAIL=your_email@example.com

# --- Bundestag DIP API ---
# Key pubblica gratuita (default inclusa nel wrapper)
# Per key dedicata: parlamentsdokumentation@bundestag.de
BUNDESTAG_API_KEY=

# --- BfArM DiGA FHIR API ---
# Token pubblico estratto dalla pagina del directory
# Viene aggiornato automaticamente dal collector
DIGA_FHIR_TOKEN=116b0a73-6e3b-4a88-9313-9947a4fed9ef

# --- Email Alerts (Gmail SMTP) ---
# Attiva "App passwords" in Google Account → Security
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
ALERT_RECIPIENTS=your_email@gmail.com

# --- Streamlit ---
STREAMLIT_SERVER_PORT=8501
